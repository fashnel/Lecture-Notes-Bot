# Transcription API (e.g. Groq Whisper)
TRANSCRIPTION_API_KEY=your_transcription_api_key
TRANSCRIPTION_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# LLM API (e.g. llama-3.1-70b-versatile)
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://api.groq.com/openai/v1/chat/completions
LLM_MODEL=llama-3.1-70b-versatile

# Directories
INCOMING_DIR=/data/incoming
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# LLM Prompt
LLM_SYSTEM_PROMPT="Ты — генератор учебных материалов. Твоя задача: преобразовать транскрипцию лекции в красивый и структурированный HTML-документ.ТРЕБОВАНИЯ К ВЫВОДУ: Верни ТОЛЬКО валидный HTML-код. Используй современные шрифты (например, 'Liberation Sans', sans-serif). Добавь внутри тега <style>: body { line-height: 1.6; color: #333; } h1 { color: #2c3e50; border-bottom: 2px solid #eee; } .term { font-weight: bold; color: #e67e22; } pre { background: #f8f9fa; padding: 10px; border: 1px solid #ddd; border-radius: 5px; } Используй семантические теги: <header>, <section>, <code>, <table>. Исправляй ошибки речи, делай текст логичным и профессиональным."

# Retry settings
MAX_RETRIES=3
RETRY_WAIT_SECONDS=5

# Proxys
HTTP_PROXY=http://user:password@ip:port
HTTPS_PROXY=http://user:password@ip:port

# Transcription API (e.g. Groq Whisper)
TRANSCRIPTION_API_KEY=your_transcription_api_key
TRANSCRIPTION_API_URL=https://api.groq.com/openai/v1/audio/transcriptions
TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# LLM API (e.g. google/gemma-4-26b-a4b-it:free)
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=google/gemma-4-26b-a4b-it:free

# Directories
INCOMING_DIR=/data/incoming
OUTPUT_DIR=/data/output
TEMP_DIR=/data/temp

# LLM Prompt
LLM_SYSTEM_PROMPT="Сделай подробный конспект лекции в Markdown"

# Retry settings
MAX_RETRIES=3
RETRY_WAIT_SECONDS=5
